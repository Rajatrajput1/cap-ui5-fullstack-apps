<mvc:View controllerName="student.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
       <content>

        <!-- Header Toolbar -->
        <Toolbar id="_IDGenToolbar">
            <Title id="_IDGenTitle" text="Student Manager"/>
            <ToolbarSpacer id="_IDGenToolbarSpacer1"/>
            <Button id="_IDGenButton" text="Add Student" press="onOpenDialog" type="Emphasized"/>
        </Toolbar>

        <!-- Filters -->
        <Toolbar id="_IDGenToolbar1" class="sapUiSmallMarginTop">

            <Label id="_IDGenLabel" text="Name"/>
            <Input id="filterName" placeholder="Enter Name" width="150px"/>
            
            <Label id="_IDGenLabel1" text="Course"/>
            <Input id="filterCourse" placeholder="Enter Course" width="150px"/>

            <Button id="_IDGenButton1" text="Apply Filters" press="onApplyFilter" type="Emphasized"/>      
            <Button id="_IDGenButton2" text="Clear" press="onClearFilter"/>

        </Toolbar>

        <!-- Chart -->
        <VBox id="_IDGenVBox" class="sapUiSmallMarginTop">
            <viz:VizFrame id="idVizFrame"
                width="100%"
                height="300px"
                vizType="column"
                xmlns:viz="sap.viz.ui5.controls"/>
        </VBox>

        <!--  Table -->
        <Table id="studentTable" items="{/Students}" growing="true" class="sapUiSmallMarginTop">

            <columns>
                <Column id="_IDGenColumn"><Text id="_IDGenText" text="Name"/></Column>
                <Column id="_IDGenColumn1"><Text id="_IDGenText1" text="Age"/></Column>
                <Column id="_IDGenColumn2"><Text id="_IDGenText2" text="Course"/></Column>
                <Column id="_IDGenColumn3"><Text id="_IDGenText3" text="Action"/></Column>
            </columns>

            <items>
                <ColumnListItem id="_IDGenColumnListItem">
                    <cells>
                        <Text id="_IDGenText4" text="{name}"/>
                        <ObjectStatus id="_IDGenObjectStatus" text="{age}" state="Information"/>
                        <Text id="_IDGenText5" text="{course}"/>

                        <HBox id="_IDGenHBox">
                            <Button id="_IDGenButton3" icon="sap-icon://edit" press="onEdit"/>
                            <Button id="_IDGenButton4" icon="sap-icon://delete" type="Reject" press="onDelete"/>
                        </HBox>

                    </cells>
                </ColumnListItem>
            </items>

        </Table>

    </content>

    
    <Dialog id="addDialog" title="Add Student" draggable="true" resizable="true">
        <VBox id="_IDGenVBox1" class="sapUiSmallMargin">

            <Label id="_IDGenLabel2" text="Name"/>
            <Input id="nameInput" required="true"/>

            <Label id="_IDGenLabel3" text="Age"/>
            <Input id="ageInput" type="Number" required="true"/>

            <Label id="_IDGenLabel4" text="Course"/>
            <Input id="courseInput" required="true"/>

        </VBox>

        <beginButton>
            <Button id="_IDGenButton5" text="Save" type="Emphasized" press="onCreateStudent"/>
        </beginButton>

        <endButton>
            <Button id="_IDGenButton6" text="Cancel" press="onCloseDialog"/>
        </endButton>
    </Dialog>
    
    </Page>
</mvc:View>