{
  "name": "cap_master",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/db-service": "^2.9.0",
    "@cap-js/hana": "^2.7.0",
    "@sap/cds": "^9.8.5",
    "@sap/xssec": "^4",
    "eslint": "^10.2.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-student": "cds watch --open student/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-book": "cds watch --open book/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy cap_master --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-order": "cds watch --open order/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employee": "cds watch --open employee/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-product": "cds watch --open product/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-feedback": "cds watch --open feedback/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ]
}
